\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Unified framework for evaluating document chunking strategies across retrieval paradigms. Documents from BEIR and GutenQA datasets are segmented using one of several methods: fixed-size, paragraph-based, sentence-based, semantic sentence-based, propositional, or LLM-guided chunking (e.g., LumberChunker). Depending on the configuration, embeddings are generated either before chunking (\textit  {pre-embedding chunking}) or after full-document encoding (\textit  {contextualized chunking}, e.g., Late Chunking). Resulting chunk embeddings are indexed and evaluated under two retrieval settings: (1) \textit  {in-document retrieval} (needle-in-a-haystack) and (2) \textit  {in-corpus retrieval} (multi-document). The pipeline supports multiple embedding and generative model families (e.g., \textsc  {E5}, \textsc  {Jina}, \textsc  {Nomic}, \textsc  {OpenAI})~\cite  {E5-OpenAI}, enabling controlled comparison across chunking paradigms and model capacities.}}{4}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:chunking-embedding-pipeline}{{1}{4}{Unified framework for evaluating document chunking strategies across retrieval paradigms. Documents from BEIR and GutenQA datasets are segmented using one of several methods: fixed-size, paragraph-based, sentence-based, semantic sentence-based, propositional, or LLM-guided chunking (e.g., LumberChunker). Depending on the configuration, embeddings are generated either before chunking (\textit {pre-embedding chunking}) or after full-document encoding (\textit {contextualized chunking}, e.g., Late Chunking). Resulting chunk embeddings are indexed and evaluated under two retrieval settings: (1) \textit {in-document retrieval} (needle-in-a-haystack) and (2) \textit {in-corpus retrieval} (multi-document). The pipeline supports multiple embedding and generative model families (e.g., \textsc {E5}, \textsc {Jina}, \textsc {Nomic}, \textsc {OpenAI})~\cite {E5-OpenAI}, enabling controlled comparison across chunking paradigms and model capacities}{figure.caption.2}{}}
